# ping-mem Production Environment Variables
# Copy to .env on VPS: cp .env.prod.template .env && edit values

# Neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# API Authentication
PING_MEM_API_KEY=CHANGE_ME_API_KEY

# Admin Panel
PING_MEM_ADMIN_USER=admin
PING_MEM_ADMIN_PASS=CHANGE_ME_ADMIN_PASSWORD

# Encryption
PING_MEM_SECRET_KEY=CHANGE_ME_32_CHAR_SECRET_KEY

# Qdrant
QDRANT_COLLECTION_NAME=ping-mem-vectors
QDRANT_VECTOR_DIMENSIONS=768

# Agent limits
PING_MEM_MAX_AGENTS=100
